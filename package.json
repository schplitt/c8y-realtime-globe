{
  "name": "realtime-globe",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "description": "A Cumulocity dashboard widget that renders a 3D interactive globe and visualizes incoming measurements in realtime.",
  "keywords": [
    "cumulocity",
    "widget",
    "globe",
    "realtime",
    "measurements",
    "3d"
  ],
  "license": "Apache-2.0",
  "author": "schplitt",
  "homepage": "https://github.com/schplitt/realtime-globe#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/schplitt/realtime-globe"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve -u https://hockjakob.eu-latest.cumulocity.com/ --shell cockpit",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prerelease": "eslint && ng build",
    "release": "bumpp"
  },
  "dependencies": {
    "@angular/cdk": "catalog:",
    "@angular/common": "catalog:",
    "@angular/compiler": "catalog:",
    "@angular/core": "catalog:",
    "@angular/forms": "catalog:",
    "@angular/platform-browser": "catalog:",
    "@angular/router": "catalog:",
    "@c8y/bootstrap": "catalog:",
    "@c8y/client": "catalog:",
    "@c8y/ngx-components": "catalog:",
    "@c8y/style": "catalog:",
    "@event-globe/ts": "catalog:",
    "dotenv": "catalog:",
    "monaco-editor": "catalog:",
    "ngx-bootstrap": "catalog:",
    "rxjs": "catalog:",
    "tslib": "catalog:",
    "zone.js": "catalog:"
  },
  "devDependencies": {
    "@angular/build": "catalog:",
    "@angular/cli": "catalog:",
    "@angular/compiler-cli": "catalog:",
    "@c8y/devkit": "catalog:",
    "@c8y/options": "catalog:",
    "@schplitt/eslint-config": "catalog:",
    "bumpp": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
